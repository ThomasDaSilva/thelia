# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Database connection for tests.
# Uses the same database as dev — test isolation is ensured by
# IntegrationTestCase (transaction rollback per test).
# Override in .env.test.local if you need a dedicated test database.
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_NAME=db
DATABASE_USER=db
DATABASE_PASSWORD=db
